# clearsky configuration. Copy to `.env` (git-ignored). Real env vars override these.
# All variables are optional — sensible defaults are baked in for Donvale, VIC.

# --- Server ---
CLEARSKY_ADDR=:8080
CLEARSKY_DB=clearsky.db
CLEARSKY_BASE_URL=http://localhost:8080
CLEARSKY_LOG_LEVEL=info          # debug | info | warn | error

# --- Site + schedule ---
CLEARSKY_TZ=Australia/Melbourne
CLEARSKY_RUN_HOUR=18             # daily check fires at this local time
CLEARSKY_RUN_MINUTE=0
CLEARSKY_LAT=-37.79              # Donvale
CLEARSKY_LON=145.18
CLEARSKY_CATCHUP_ON_START=true   # on boot, run today's check if it hasn't run yet

# --- Weather source ---
# agreement = Open-Meteo AND yr.no must BOTH be clear (most conservative, default).
# open-meteo / met-no = use a single provider.
CLEARSKY_SOURCE=agreement
# MET Norway (yr.no) REQUIRES a descriptive User-Agent with contact info.
CLEARSKY_METNO_USER_AGENT=clearsky-astro/1.0 (+https://deepspaceplace.com)

# --- Visual "Tonight" panel images (eyeball check; not used by the decision) ---
# Defaults are derived for Donvale/Melbourne. Override if you move.
#CLEARSKY_CLEAROUTSIDE_IMG=https://clearoutside.com/forecast_image_large/-37.79/145.18/forecast.png
#CLEARSKY_YR_METEOGRAM=https://www.yr.no/en/content/2-2158177/meteogram.svg
#CLEARSKY_SKIPPY_IMG=http://www.skippysky.com.au/Melbourne/cloud_total/melb_006_cct.png
#CLEARSKY_DEEPSPACE_URL=https://deepspaceplace.com/weather

# --- Decision thresholds (rain veto + cloud gate; moon is info-only) ---
CLEARSKY_RAIN_MM_VETO_HOUR=0.0   # any measurable rain in an hour -> NO-GO
CLEARSKY_RAIN_PROB_VETO_PCT=20   # per-hour rain probability above this -> NO-GO
CLEARSKY_RAIN_MM_TOTAL_VETO=0.2  # window total precip above this -> NO-GO
CLEARSKY_CLOUD_AVG_MAX_PCT=25    # mean cloud across the night must be <= this
CLEARSKY_CLOUD_MAX_PCT=40        # peak cloud must be <= this (allows small patches)
CLEARSKY_CLOUD_LOW_MAX_PCT=15    # low cloud is worst — tight cap
CLEARSKY_CLOUD_MID_MAX_PCT=25    # mid cloud cap
CLEARSKY_VIS_MIN_M=20000         # below this, a haze note is added (no veto)

# --- Notifications (GO nights only). Leave blank to disable a channel. ---
CLEARSKY_DISCORD_WEBHOOK_URL=
# Gmail: create an App Password (needs 2FA) and use it here, not your login password.
CLEARSKY_SMTP_HOST=smtp.gmail.com
CLEARSKY_SMTP_PORT=587
CLEARSKY_SMTP_USER=
CLEARSKY_SMTP_PASS=
CLEARSKY_EMAIL_TO=
